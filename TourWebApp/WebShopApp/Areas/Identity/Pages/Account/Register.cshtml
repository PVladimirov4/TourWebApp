@page
@model RegisterModel
@{
    ViewData["Title"] = "Регистрация";
}

<style>
    .register-wrapper {
        min-height: 90vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 20px;
    }

    .register-card {
        background: white;
        border-radius: 24px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.1);
        width: 100%;
        max-width: 600px; /* Малко по-широка за повечето полета */
        overflow: hidden;
        border: none;
    }

    .register-header {
        background: #2563eb;
        padding: 40px;
        text-align: center;
        color: white;
    }

    .register-header i {
        font-size: 2.5rem;
        margin-bottom: 10px;
    }

    .register-body {
        padding: 40px;
    }

    .section-divider {
        font-size: 0.85rem;
        font-weight: 700;
        text-transform: uppercase;
        color: #94a3b8;
        letter-spacing: 1px;
        margin: 25px 0 15px;
        display: flex;
        align-items: center;
    }

    .section-divider::after {
        content: "";
        flex: 1;
        height: 1px;
        background: #e2e8f0;
        margin-left: 15px;
    }

    .form-floating {
        margin-bottom: 15px;
    }

    .btn-register-action {
        background: #2563eb;
        border: none;
        padding: 15px;
        border-radius: 12px;
        font-weight: 700;
        transition: all 0.3s;
        margin-top: 20px;
    }

    .btn-register-action:hover {
        background: #1d4ed8;
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(37, 99, 235, 0.2);
    }

    .login-prompt {
        margin-top: 25px;
        text-align: center;
        font-size: 0.9rem;
    }
</style>

<div class="register-wrapper">
    <div class="register-card">
        <div class="register-header">
            <i class="bi bi-person-plus-fill"></i>
            <h2 class="fw-bold mb-0">Създаване на акаунт</h2>
            <p class="opacity-75 mb-0">Присъединете се към WebShopApp днес</p>
        </div>

        <div class="register-body">
            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                <div class="section-divider">Лична информация</div>

                <div class="row g-2">
                    <div class="col-md-6">
                        <div class="form-floating">
                            <input asp-for="Input.FirstName" class="form-control rounded-3" placeholder="Име" />
                            <label asp-for="Input.FirstName">Име</label>
                            <span asp-validation-for="Input.FirstName" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating">
                            <input asp-for="Input.LastName" class="form-control rounded-3" placeholder="Фамилия" />
                            <label asp-for="Input.LastName">Фамилия</label>
                            <span asp-validation-for="Input.LastName" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                <div class="form-floating">
                    <input asp-for="Input.Address" class="form-control rounded-3" placeholder="Адрес" />
                    <label asp-for="Input.Address">Адрес</label>
                    <span asp-validation-for="Input.Address" class="text-danger small"></span>
                </div>

                <div class="section-divider">Данни за профила</div>

                <div class="form-floating">
                    <input asp-for="Input.UserName" class="form-control rounded-3" placeholder="Потребителско име" />
                    <label asp-for="Input.UserName">Потребителско име</label>
                    <span asp-validation-for="Input.UserName" class="text-danger small"></span>
                </div>

                <div class="form-floating">
                    <input asp-for="Input.Email" class="form-control rounded-3" placeholder="name@example.com" />
                    <label asp-for="Input.Email">Имейл</label>
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="row g-2">
                    <div class="col-md-6">
                        <div class="form-floating">
                            <input asp-for="Input.Password" class="form-control rounded-3" type="password" placeholder="Парола" />
                            <label asp-for="Input.Password">Парола</label>
                            <span asp-validation-for="Input.Password" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating">
                            <input asp-for="Input.ConfirmPassword" class="form-control rounded-3" type="password" placeholder="Потвърди парола" />
                            <label asp-for="Input.ConfirmPassword">Потвърди парола</label>
                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                <button id="registerSubmit" type="submit" class="w-100 btn btn-lg btn-primary btn-register-action shadow">
                    Регистрирай ме
                </button>

                <div class="login-prompt">
                    <span class="text-muted">Вече имате профил?</span>
                    <a asp-page="./Login" class="text-primary fw-bold text-decoration-none ms-1">Влезте оттук</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}