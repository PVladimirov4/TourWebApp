@model TourWebApp.Models.Holiday.HolidayCreateVM

@{
    ViewData["Title"] = "Създаване на екскурзия";
}

<style>
    body {
        background-color: #f4f7f6;
    }

    .card {
        border: none;
        transition: transform 0.3s ease;
        background: #ffffff;
        border-radius: 15px;
    }

    .card-header {
        background: linear-gradient(45deg, #007bff, #0056b3) !important;
        border-bottom: none;
        border-radius: 15px 15px 0 0 !important;
        padding: 1.5rem;
    }

    h5.text-primary {
        letter-spacing: 1px;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.85rem;
        color: #0056b3 !important;
    }

    .form-control, .form-select {
        border: 1px solid #e0e0e0;
        padding: 0.70rem 1rem;
        border-radius: 10px;
        transition: all 0.2s ease-in-out;
    }

        .form-control:focus, .form-select:focus {
            border-color: #007bff;
            box-shadow: 0 0 0 0.25rem rgba(0, 123, 255, 0.1);
            background-color: #fff;
        }

    .input-group-text {
        background-color: #f8f9fa;
        border: 1px solid #e0e0e0;
        color: #6c757d;
        border-radius: 10px 0 0 10px;
    }

    .btn-primary {
        background: linear-gradient(45deg, #007bff, #0056b3);
        border: none;
        padding: 14px;
        font-weight: 600;
        border-radius: 10px;
        transition: all 0.3s ease;
    }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0, 123, 255, 0.3);
            filter: brightness(1.1);
        }

    .tour-section {
        background: #fafafa;
        padding: 20px;
        border-radius: 12px;
        margin-bottom: 25px;
        border: 1px solid #f0f0f0;
    }
</style>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10 col-xl-8">
            <div class="card shadow-lg">

                <div class="card-header text-white text-center">
                    <h2 class="mb-0"><i class="bi bi-airplane-fill me-2"></i>Създаване на нова оферта</h2>
                    <p class="mb-0 opacity-75">Попълнете детайлите, за да пуснете нова дестинация</p>
                </div>

                <div class="card-body p-4 p-md-5">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4" role="alert"></div>

                        <div class="tour-section shadow-sm">
                            <h5 class="text-primary mb-4"><i class="bi bi-info-circle me-2"></i>Обща информация</h5>

                            <div class="mb-4">
                                <label asp-for="HolidayName" class="form-label fw-bold small">Име на почивката</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-map"></i></span>
                                    <input asp-for="HolidayName" class="form-control" placeholder="напр. Уикенд в Рим" />
                                </div>
                                <span asp-validation-for="HolidayName" class="text-danger small"></span>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-4">
                                    <label asp-for="CountryId" class="form-label fw-bold small">Държава</label>
                                    <select asp-for="CountryId" class="form-select">
                                        <option value="">-- Изберете държава --</option>
                                        @foreach (var country in Model.Countrys)
                                        {
                                            <option value="@country.Id">@country.Name</option>
                                        }
                                    </select>
                                    <span asp-validation-for="CountryId" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6 mb-4">
                                    <label asp-for="CategoryId" class="form-label fw-bold small">Категория</label>
                                    <select asp-for="CategoryId" class="form-select">
                                        <option value="">-- Изберете категория --</option>
                                        @foreach (var category in Model.Categories)
                                        {
                                            <option value="@category.Id">@category.Name</option>
                                        }
                                    </select>
                                    <span asp-validation-for="CategoryId" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="tour-section shadow-sm">
                            <h5 class="text-primary mb-4"><i class="bi bi-calendar3 me-2"></i>График на пътуването</h5>
                            <div class="row">
                                <div class="col-md-6 mb-4">
                                    <label asp-for="DepartureTime" class="form-label fw-bold small">Заминаване (Дата и час)</label>
                                    <input asp-for="DepartureTime" class="form-control" type="datetime-local" />
                                    <span asp-validation-for="DepartureTime" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6 mb-4">
                                    <label asp-for="ArrivalDate" class="form-label fw-bold small">Дата на връщане</label>
                                    <input asp-for="ArrivalDate" class="form-control" type="date" />
                                    <span asp-validation-for="ArrivalDate" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="tour-section shadow-sm">
                            <h5 class="text-primary mb-4"><i class="bi bi-cash-stack me-2"></i>Цени и капацитет</h5>
                            <div class="row">
                                <div class="col-md-4 mb-4">
                                    <label asp-for="Price" class="form-label fw-bold small">Цена</label>
                                    <div class="input-group">
                                        <span class="input-group-text">лв.</span>
                                        <input asp-for="Price" class="form-control" placeholder="0.00" />
                                    </div>
                                    <span asp-validation-for="Price" class="text-danger small"></span>
                                </div>
                                <div class="col-md-4 mb-4">
                                    <label asp-for="Discount" class="form-label fw-bold small">Отстъпка</label>
                                    <div class="input-group">
                                        <input asp-for="Discount" class="form-control" placeholder="0" />
                                        <span class="input-group-text">%</span>
                                    </div>
                                    <span asp-validation-for="Discount" class="text-danger small"></span>
                                </div>
                                <div class="col-md-4 mb-4">
                                    <label asp-for="Quantity" class="form-label fw-bold small">Свободни места</label>
                                    <input asp-for="Quantity" class="form-control" placeholder="напр. 20" />
                                    <span asp-validation-for="Quantity" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="mb-4">
                                <label asp-for="Picture" class="form-label fw-bold small">Линк към водеща снимка</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-link-45deg"></i></span>
                                    <input asp-for="Picture" class="form-control" placeholder="https://..." />
                                </div>
                                <span asp-validation-for="Picture" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label fw-bold">Описание на дестинацията</label>
                            <textarea asp-for="Description" class="form-control" rows="4" placeholder="Разкажете на пътешествениците какво прави тази екскурзия специална..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="row mt-5">
                            <div class="col-md-6 mb-2">
                                <a asp-action="Index" class="btn btn-outline-secondary w-100">
                                    <i class="bi bi-arrow-left me-2"></i>Назад към списъка
                                </a>
                            </div>
                            <div class="col-md-6">
                                <button type="submit" class="btn btn-primary w-100">
                                    <i class="bi bi-plus-lg me-2"></i>Създай екскурзия
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}