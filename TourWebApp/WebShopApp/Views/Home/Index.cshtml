@{
    ViewData["Title"] = "Добре дошли в TourWebApp";
}

<style>
    /* Основен контейнер с плавно появяване */
    .fade-in-page {
        animation: fadeIn 1.5s ease-in;
    }

    /* Hero секция с паралакс ефект */
    .hero-v2 {
        position: relative;
        height: 85vh;
        background: url('https://images.unsplash.com/photo-1476514525535-07fb3b4ae5f1?ixlib=rb-4.0.3&auto=format&fit=crop&w=1470&q=80') center/cover no-repeat fixed;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 0 0 80px 80px;
        color: white;
        text-align: center;
        overflow: hidden;
    }

    .hero-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.4);
        backdrop-filter: blur(2px);
    }

    .hero-content-v2 {
        position: relative;
        z-index: 2;
        max-width: 800px;
    }

        .hero-content-v2 h1 {
            font-size: 5rem;
            font-weight: 900;
            letter-spacing: -2px;
            line-height: 1;
            margin-bottom: 20px;
        }

        .hero-content-v2 p {
            font-size: 1.4rem;
            font-weight: 300;
            margin-bottom: 30px;
            opacity: 0.9;
        }

    /* Секция с характеристики (Features) */
    .feature-box {
        padding: 60px 0;
        background: #fff;
    }

    .feature-item {
        transition: all 0.3s ease;
        padding: 30px;
        border-radius: 20px;
    }

        .feature-item:hover {
            background: #f8f9fa;
            transform: translateY(-10px);
        }

    .feature-icon {
        width: 70px;
        height: 70px;
        background: #eef2ff;
        color: #4f46e5;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        border-radius: 18px;
        margin: 0 auto 20px;
    }

    /* Анимиран бутон */
    .btn-explore {
        background: white;
        color: #1a202c;
        padding: 15px 40px;
        font-weight: 700;
        border-radius: 50px;
        text-decoration: none;
        transition: all 0.3s;
        border: 2px solid white;
    }

        .btn-explore:hover {
            background: transparent;
            color: white;
            box-shadow: 0 10px 20px rgba(0,0,0,0.2);
        }

    /* Текстова секция с акцент */
    .quote-section {
        padding: 100px 0;
        background: linear-gradient(to right, #ffffff, #f3f4f6);
        text-align: center;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }
</style>

<div class="fade-in-page">
    <div class="hero-v2 shadow-lg">
        <div class="hero-overlay"></div>
        <div class="hero-content-v2 px-3">
            <h1>Пътувай.<br>Мечтай.<br>Откривай.</h1>
            <p>Ние не просто организираме екскурзии. Ние създаваме спомени, които остават за цял живот.</p>
            <div class="mt-5">
                <a asp-controller="Holiday" asp-action="Index" class="btn-explore">
                    ЗАПОЧНИ ПРИКЛЮЧЕНИЕТО <i class="bi bi-arrow-right ms-2"></i>
                </a>
            </div>
        </div>
    </div>

    <section class="feature-box">
        <div class="container">
            <div class="row text-center g-4">
                <div class="col-md-4">
                    <div class="feature-item">
                        <div class="feature-icon">
                            <i class="bi bi-map"></i>
                        </div>
                        <h4 class="fw-bold">Уникални маршрути</h4>
                        <p class="text-muted">Внимателно подбрани дестинации, далеч от масовия туризъм.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="feature-item">
                        <div class="feature-icon">
                            <i class="bi bi-compass"></i>
                        </div>
                        <h4 class="fw-bold">Опитни водачи</h4>
                        <p class="text-muted">Нашите гидове познават всяко кътче и всяка история.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="feature-item">
                        <div class="feature-icon">
                            <i class="bi bi-stars"></i>
                        </div>
                        <h4 class="fw-bold">Премиум качество</h4>
                        <p class="text-muted">Най-добрите хотели и транспорт за вашето удобство.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="quote-section">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-md-8">
                    <i class="bi bi-quote display-1 text-primary opacity-25"></i>
                    <h2 class="display-6 fw-light italic">"Светът е книга и тези, които не пътуват, четат само една страница."</h2>
                    <p class="mt-3 text-uppercase fw-bold text-muted tracking-widest">— Св. Августин</p>
                </div>
            </div>
        </div>
    </section>
</div>