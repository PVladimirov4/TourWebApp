@{
    ViewData["Title"] = "Контакти";
}

<style>
    .contact-wrapper {
        padding: 60px 0;
        background-color: #f8fafc;
    }

    .contact-info-card {
        background: white;
        border-radius: 20px;
        padding: 40px;
        height: 100%;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }

    /* Стил за контейнера на картата */
    .map-card {
        background: white;
        border-radius: 20px;
        padding: 15px; /* Малка рамка около картата */
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        height: 100%;
        min-height: 450px;
    }

    .map-container {
        width: 100%;
        height: 100%;
        border-radius: 15px;
        overflow: hidden;
    }

    .info-item {
        display: flex;
        align-items: center;
        margin-bottom: 25px;
    }

    .info-icon {
        width: 50px;
        height: 50px;
        background: rgba(37, 99, 235, 0.1);
        color: #2563eb;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        margin-right: 20px;
    }

    .info-text h5 {
        margin-bottom: 2px;
        font-weight: 700;
        color: #1e293b;
    }

    .info-text p {
        margin-bottom: 0;
        color: #64748b;
    }
</style>

<div class="contact-wrapper">
    <div class="container">
        <div class="text-center mb-5">
            <h1 class="fw-bold text-dark">Къде да ни намерите</h1>
            <p class="text-muted">Заповядайте в нашия офис за консултация относно вашата следваща дестинация!</p>
        </div>

        <div class="row g-4">
            <div class="col-lg-5">
                <div class="contact-info-card">
                    <h3 class="fw-bold mb-4">Информация</h3>

                    <div class="info-item">
                        <div class="info-icon">
                            <i class="bi bi-geo-alt-fill"></i>
                        </div>
                        <div class="info-text">
                            <h5>Адрес</h5>
                            <p>ПМГ "Христо Смирненски", ул. „8-ми март“ 2, 2306 Перник</p>
                        </div>
                    </div>

                    <div class="info-item">
                        <div class="info-icon">
                            <i class="bi bi-telephone-fill"></i>
                        </div>
                        <div class="info-text">
                            <h5>Телефон</h5>
                            <p>+359 76 600 000</p>
                        </div>
                    </div>

                    <div class="info-item">
                        <div class="info-icon">
                            <i class="bi bi-envelope-at-fill"></i>
                        </div>
                        <div class="info-text">
                            <h5>Имейл</h5>
                            <p>office@tourwebapp.com</p>
                        </div>
                    </div>

                    <div class="info-item">
                        <div class="info-icon">
                            <i class="bi bi-clock-fill"></i>
                        </div>
                        <div class="info-text">
                            <h5>Работно време</h5>
                            <p>Пон - Пет: 09:00 - 18:00</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-7">
                <div class="map-card">
                    <div class="map-container">
                        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2936.550679690272!2d23.030333677518055!3d42.60727577117104!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x14aacac3bbc30045%3A0x1282864432d70ccb!2z0J_QnNCTICLQpdGA0LjRgdGC0L4g0KHQvNC40YDQvdC10L3RgdC60Lgi!5e0!3m2!1sbg!2sbg!4v1776588984513!5m2!1sbg!2sbg" 
                        width="600"
                        height="450" 
                        style="border:0;"
                        allowfullscreen=""
                        loading="lazy" 
                        referrerpolicy="no-referrer-when-downgrade">
                    </iframe>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>