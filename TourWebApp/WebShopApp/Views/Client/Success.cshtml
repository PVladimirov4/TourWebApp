@{
    ViewData["Title"] = "Успешно изтриване";
}

<style>
    .success-wrapper {
        min-height: 60vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .success-card {
        background: white;
        padding: 50px;
        border-radius: 30px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.05);
        text-align: center;
        max-width: 500px;
        border-bottom: 6px solid #10b981; /* Зелена линия за успех */
    }

    .success-icon-circle {
        width: 90px;
        height: 90px;
        background: #ecfdf5;
        color: #10b981;
        font-size: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        margin: 0 auto 25px;
        animation: scaleIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    @@keyframes scaleIn {
        from { transform: scale(0); opacity: 0; }
        to { transform: scale(1); opacity: 1; }
    }

    .btn-done {
        background: #10b981;
        color: white;
        padding: 12px 35px;
        border-radius: 50px;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.3s;
        display: inline-block;
        margin-top: 20px;
        border: none;
    }

    .btn-done:hover {
        background: #059669;
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(16, 185, 129, 0.3);
    }
</style>

<div class="success-wrapper">
    <div class="success-card">
        <div class="success-icon-circle">
            <i class="bi bi-check-lg"></i>
        </div>

        <h2 class="fw-bold text-dark mb-3">Операцията е успешна!</h2>

        <p class="text-muted mb-4">
            Потребителят беше премахнат окончателно от базата данни. Всички свързани системни логове са актуализирани.
        </p>

        <div class="py-2 px-3 bg-light rounded-pill d-inline-block mb-4">
            <small class="text-success fw-bold">
                <i class="bi bi-info-circle me-1"></i> Списъкът с клиенти е обновен
            </small>
        </div>

        <div class="d-block">
            <a asp-action="Index" class="btn-done shadow-sm">
                <i class="bi bi-arrow-left me-2"></i> Обратно към списъка
            </a>
        </div>
    </div>
</div>
