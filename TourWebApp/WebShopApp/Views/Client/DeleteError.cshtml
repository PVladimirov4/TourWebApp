@{
    ViewData["Title"] = "Действието е отказано";
}

<style>
    .error-wrapper {
        min-height: 70vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .lock-card {
        background: white;
        padding: 60px 40px;
        border-radius: 30px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.05);
        text-align: center;
        max-width: 550px;
        border: 1px solid #e2e8f0;
    }

    .lock-icon-circle {
        width: 100px;
        height: 100px;
        background: #fff5f5;
        color: #f56565;
        font-size: 45px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        margin: 0 auto 25px;
        border: 2px solid #fed7d7;
        animation: pulse-red 2s infinite;
    }

    @@keyframes pulse-red {
        0% { transform: scale(1); box-shadow: 0 0 0 0 rgba(245, 101, 101, 0.4); }
        70% { transform: scale(1.05); box-shadow: 0 0 0 15px rgba(245, 101, 101, 0); }
        100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(245, 101, 101, 0); }
    }

    .btn-back-admin {
        background: #4a5568;
        color: white;
        padding: 12px 30px;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.3s;
        display: inline-block;
        margin-top: 25px;
    }

    .btn-back-admin:hover {
        background: #2d3748;
        color: white;
        transform: translateY(-2px);
    }

    .reason-box {
        background: #f8fafc;
        border-radius: 15px;
        padding: 15px;
        margin-top: 20px;
        font-size: 0.9rem;
        color: #64748b;
        border-left: 4px solid #cbd5e1;
    }
</style>

<div class="error-wrapper">
    <div class="lock-card">
        <div class="lock-icon-circle">
            <i class="bi bi-shield-lock-fill"></i>
        </div>

        <h2 class="fw-bold text-dark mb-3">Грешка при изтриване</h2>
        <p class="text-muted">
            Системата не позволява изтриването на този потребител в момента.
        </p>

        <div class="reason-box text-start">
            <strong>Възможни причини:</strong>
            <ul class="mb-0 mt-2">
                <li>Потребителят има активни или минали резервации.</li>
                <li>Това е системен администраторски акаунт.</li>
                <li>Акаунтът е свързан с финансови записи.</li>
            </ul>
        </div>

        <a asp-controller="Client" asp-action="Index" class="btn-back-admin shadow-sm">
            <i class="bi bi-arrow-left me-2"></i> Обратно към списъка
        </a>
    </div>
</div>