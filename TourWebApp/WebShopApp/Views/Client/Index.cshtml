@model IEnumerable<TourWebApp.Models.Client.ClientIndexVM>
@{
    ViewData["Title"] = "Списък с клиенти";
}

<style>
    .admin-card {
        background: white;
        border-radius: 15px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.05);
        padding: 30px;
        margin-top: 30px;
    }

    .table thead th {
        background-color: #f8fafc;
        border-bottom: 2px solid #e2e8f0;
        color: #64748b;
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 1px;
        padding: 15px;
    }

    .table tbody td {
        vertical-align: middle;
        padding: 15px;
        color: #334155;
        border-bottom: 1px solid #f1f5f9;
    }

    .user-avatar {
        width: 35px;
        height: 35px;
        background: #e2e8f0;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-right: 10px;
        color: #475569;
    }

    .btn-delete-custom {
        color: #ef4444;
        background: #fef2f2;
        border: 1px solid #fee2e2;
        padding: 6px 12px;
        border-radius: 8px;
        transition: all 0.2s;
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 600;
    }

    .btn-delete-custom:hover {
        background: #dc2626;
        color: white;
        box-shadow: 0 4px 12px rgba(220, 38, 38, 0.2);
    }

    .email-link {
        color: #2563eb;
        text-decoration: none;
    }

    .email-link:hover {
        text-decoration: underline;
    }
</style>

<div class="container">
    <div class="d-flex justify-content-between align-items-center mt-4">
        <div>
            <h1 class="fw-bold mb-0">Клиенти</h1>
            <p class="text-muted">Управление на регистрираните потребители в системата</p>
        </div>
        <div class="badge bg-primary px-3 py-2 rounded-pill">
            Общо: @Model.Count()
        </div>
    </div>

    <div class="admin-card">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Потребител</th>
                        <th>Имена</th>
                        <th>Адрес</th>
                        <th>Имейл</th>
                        <th class="text-end">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="user-avatar">
                                        <i class="bi bi-person"></i>
                                    </div>
                                    <span class="fw-bold">@item.UserName</span>
                                </div>
                            </td>
                            <td>
                                @item.FirstName @item.LastName
                            </td>
                            <td>
                                <small class="text-muted">@item.Address</small>
                            </td>
                            <td>
                                <a href="mailto:@item.Email" class="email-link">
                                    <i class="bi bi-envelope me-1"></i>@item.Email
                                </a>
                            </td>
                            <td class="text-end">
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn-delete-custom">
                                    <i class="bi bi-trash3 me-1"></i> Изтрий
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>