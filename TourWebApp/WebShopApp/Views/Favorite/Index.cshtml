@model IEnumerable<TourWebApp.Infrastructure.Data.Entities.Holiday>

<style>
    .tour-card {
        border-radius: 15px;
        overflow: hidden;
        transition: 0.3s;
        border: none;
        background: white;
    }

    .image-wrapper {
        position: relative; /* ТОВА Е КЛЮЧЪТ */
        height: 220px;
    }

    .favorite-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .remove-btn {
        position: absolute;
        top: 10px;
        right: 10px;
        z-index: 10;
        background-color: rgba(220, 53, 69, 0.9);
        color: white;
        border: 2px solid white;
        width: 32px;
        height: 32px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: 0.2s;
        padding: 0;
    }

        .remove-btn:hover {
            background-color: #dc3545;
            transform: scale(1.1);
            color: white;
        }
</style>

<div class="container py-5">
    <h2 class="mb-4 fw-bold"><i class="bi bi-heart-fill text-danger me-2"></i>Моите Любими</h2>

    @if (!Model.Any())
    {
        <div class="alert alert-light border text-center py-5 shadow-sm">
            <i class="bi bi-geo-alt fs-1 text-muted d-block mb-3"></i>
            <p class="mb-0">Все още нямате добавени любими екскурзии.</p>
            <a asp-controller="Holiday" asp-action="Index" class="btn btn-primary mt-3 rounded-pill">Разгледай каталога</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-md-4 col-lg-3">
                    <div class="card tour-card shadow-sm h-100">

                        <div class="image-wrapper">
                            <img src="@item.Picture" class="favorite-img" alt="@item.HolidayName">

                            <form asp-controller="Favorite" asp-action="Toggle" asp-route-holidayId="@item.Id" method="post">
                                <button type="submit" class="remove-btn shadow">
                                    <i class="bi bi-x-lg"></i>
                                </button>
                            </form>
                        </div>

                        <div class="card-body p-3">
                            <h6 class="fw-bold mb-1">@item.HolidayName</h6>
                            <p class="text-primary fw-bold mb-3">@item.Price лв.</p>

                            <div class="d-grid gap-2">
                                <a asp-controller="Holiday" asp-action="Details" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-dark rounded-pill">Детайли</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>